{
  "name": "consulting-portfolio",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @consulting/web dev",
    "dev:docflow": "pnpm --filter @consulting/docflow dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @consulting/docflow db:generate",
    "db:migrate": "pnpm --filter @consulting/docflow db:migrate",
    "db:push": "pnpm --filter @consulting/docflow db:push"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}

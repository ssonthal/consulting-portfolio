# Portfolio (apps/web) — copy to apps/web/.env.local

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
NEXT_PUBLIC_CALENDLY_URL=

# Optional: smarter chat replies when rules don't match
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: email yourself when someone submits the chat lead form
RESEND_API_KEY=
RESEND_FROM=FlowDesk <onboarding@resend.dev>
LEAD_NOTIFY_EMAIL=

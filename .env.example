# ─── Portfolio (apps/web) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
NEXT_PUBLIC_DOCFLOW_URL=http://localhost:3001
NEXT_PUBLIC_CALENDLY_URL=

# ─── DocFlow (apps/docflow) ───
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:3000

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3001

# Google Cloud OAuth (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL — local Docker OR RDS (from CloudFormation DatabaseUrl output)
DATABASE_URL=postgresql://docflow:password@localhost:5432/docflow?sslmode=require

# Token encryption — same value on Amplify AND Lambda (openssl rand -base64 32)
ENCRYPTION_KEY=

# OpenAI for PDF extraction (Lambda uses this too)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: manual cron trigger in dev only (production uses AWS Lambda)
CRON_SECRET=

DOCFLOW_MONTHLY_DOC_LIMIT=20

# ─── AWS SAM deploy (infra/scripts/deploy.sh) ───
# DB_MASTER_PASSWORD=
# ALLOW_PUBLIC_DB_ACCESS=true
